# OSS Audit 2.0 项目配置示例
# 将此文件复制为 .oss-audit.yaml 并根据项目需求修改

# 项目基本信息
project:
  name: "MyProject"              # 项目名称（可选，默认使用目录名）
  type: "web_application"        # 项目类型，影响维度权重和工具选择
                                # 支持: web_application, library, cli_tool, data_science, mobile_app, desktop_app, game
  description: "项目描述"         # 项目描述（可选）

# 工具配置覆盖
tools:
  # 全局禁用的工具
  disabled:
    - "pylint"          # 禁用pylint
    - "tslint"          # 禁用tslint（已废弃）
  
  # 额外启用的工具
  enabled:
    - "mypy"            # 启用mypy类型检查
    - "prettier"        # 启用prettier格式化检查
  
  # 工具特定配置
  configs:
    bandit:
      args: ["-r", ".", "-f", "json", "-ll"]
      exclude: ["tests/", "migrations/", "venv/"]
      timeout: 120
    
    eslint:
      config_file: ".eslintrc.custom.js"
      args: [".", "--format=json", "--max-warnings=50"]
    
    pytest:
      args: ["--tb=short", "-v", "--maxfail=10"]
      timeout: 300
    
    coverage:
      min_percentage: 70        # 最小覆盖率要求
      args: ["run", "--source=.", "-m", "pytest", "--cov-report=json"]

# 维度权重自定义（用于不同项目类型的个性化评估）
dimensions:
  security:
    weight: 0.35              # Web应用提高安全权重
    enabled: true
    min_score: 80             # 安全维度最低分数要求
  
  performance:
    weight: 0.15
    enabled: false            # 暂时禁用性能检查
  
  testing:
    weight: 0.25
    enabled: true
    min_coverage: 70          # 最小测试覆盖率
  
  documentation:
    weight: 0.15
    enabled: true
  
  quality:
    weight: 0.1
    enabled: true

# 路径排除配置
exclude:
  # 排除的目录
  paths:
    - "node_modules/"
    - "vendor/"
    - "build/"
    - "dist/"
    - "__pycache__/"
    - ".git/"
    - ".svn/"
    - "venv/"
    - ".venv/"
    - "env/"
    - ".pytest_cache/"
    - ".mypy_cache/"
    - "target/"              # Rust
    - "bin/"
    - "obj/"                 # C#
  
  # 排除的文件模式
  files:
    - "*.min.js"
    - "*_pb2.py"            # Protobuf生成文件
    - "migrations/*.py"      # Django迁移文件
    - "*.pyc"
    - "*.pyo"
    - "*.class"
    - "*.o"
    - "*.so"
    - "*.dll"
    - "*.exe"
    - "*.log"
    - "*.tmp"
    - "*~"
    - ".DS_Store"
    - "Thumbs.db"

# 报告配置
reports:
  # 生成的报告格式
  formats:
    - "html"               # HTML可视化报告
    - "json"               # JSON结构化数据
    - "pdf"                # PDF报告（需要额外依赖）
  
  # 输出目录
  output_dir: "audit_reports/"
  
  # 报告详细程度
  detail_level: "full"     # full, summary, minimal
  
  # 包含的内容
  include:
    - "executive_summary"   # 执行摘要
    - "dimension_details"   # 维度详情
    - "tool_outputs"        # 工具原始输出
    - "recommendations"     # 改进建议
    - "trend_analysis"      # 趋势分析（如果有历史数据）
  
  # 报告自定义
  custom:
    title: "项目成熟度评估报告"
    logo_url: ""            # 自定义Logo URL
    footer_text: "Generated by OSS Audit 2.0"

# CI/CD集成配置
ci:
  # 失败条件
  fail_on_score: 60          # 总分低于60分时CI失败
  fail_on_security: true     # 发现安全问题时CI失败
  fail_on_coverage: 70       # 测试覆盖率低于70%时失败
  
  # 警告条件  
  warn_on_score: 75          # 总分低于75分时CI警告
  warn_on_issues: 20         # 问题数超过20个时警告
  
  # 输出配置
  output_format: "junit"     # CI系统输出格式: junit, github, gitlab
  
  # 注释PR/MR
  comment_on_pr: true        # 是否在PR/MR上添加评估结果注释

# 通知配置（可选）
notifications:
  email:
    enabled: false
    recipients: ["dev@example.com"]
    smtp_server: "smtp.example.com"
  
  slack:
    enabled: false
    webhook_url: "https://hooks.slack.com/..."
    channel: "#dev-notifications"
  
  webhook:
    enabled: false
    url: "https://api.example.com/audit-webhook"
    headers:
      Authorization: "Bearer your-token"

# 高级配置
advanced:
  # 并行执行配置
  parallelism:
    max_workers: 4           # 最大并行工具数
    timeout_multiplier: 1.5  # 超时时间倍数
  
  # 缓存配置
  cache:
    enabled: true            # 启用结果缓存
    ttl: 3600               # 缓存生存时间（秒）
    
  # 资源限制
  resource_limits:
    max_memory_mb: 2048      # 最大内存使用（MB）
    max_cpu_percent: 80      # 最大CPU使用率
  
  # 重试配置
  retry:
    enabled: true
    max_attempts: 3
    backoff_factor: 2
  
  # 调试模式
  debug:
    enabled: false
    save_intermediate_results: false
    verbose_logging: false

# 插件配置（预留）
plugins:
  enabled: []
  
  # 自定义插件路径
  custom_paths: []
  
  # 插件配置
  config: {}